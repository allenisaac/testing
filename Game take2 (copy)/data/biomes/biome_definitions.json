{
  "frog_marsh_village": {
    "display_name": "Frog Marsh Village",
    "board_level_biome": true,

    "palette": {
      "ground_base": "#7d8f59",
      "ground_light": "#98aa6d",
      "mud": "#6b5b3d",
      "mud_dark": "#55462f",
      "water_shallow": "#85a79d",
      "water_deep": "#628b8a",
      "reeds": "#8fa84a",
      "foliage_dark": "#33451f",
      "foliage_mid": "#556c2e",
      "wood": "#6a4a2c",
      "wood_light": "#8f6a45",
      "stone": "#8a8572",
      "roof_warm": "#c77838",
      "wall_light": "#d7cfaa"
    },

    "camera_rules": {
      "mode": "isometric_painted",
      "pitch_style": "illustrated_iso",
      "use_true_perspective": false
    },

    "render_rules": {
      "base_ground_mode": "painted_underlay",
      "hex_overlay_default": true,
      "hex_overlay_opacity": 0.28,
      "shoreline_softness": 0.8,
      "detail_density_global": 0.6,
      "region_edge_emphasis": 0.7
    },

    "paint_passes": {
      "base_underpaint": {
        "enabled": true,
        "noise_strength": 0.22,
        "brush_scale": 1.0
      },
      "terrain_breakup": {
        "enabled": true,
        "noise_strength": 0.35,
        "brush_scale": 0.65
      },
      "edge_blending": {
        "enabled": true,
        "softness": 0.75
      },
      "decal_pass": {
        "enabled": true,
        "density": 0.55
      }
    },

    "region_rules": {
      "water": {
        "large_region_threshold": 4,
        "very_large_region_threshold": 8,
        "allow_multi_hex_lily_clusters": true,
        "allow_shoreline_reeds": true,
        "shore_decor_density": 0.7,
        "center_open_water_bias": 0.65
      },
      "wet_ground": {
        "mud_patch_density": 0.5,
        "reed_cluster_density": 0.25,
        "puddle_density": 0.35
      },
      "boardwalk": {
        "moss_overlay_density": 0.35,
        "rope_post_chance": 0.2,
        "broken_plank_chance": 0.08
      },
      "settlement": {
        "house_cluster_density": 0.45,
        "lantern_density": 0.08,
        "fence_stub_density": 0.15
      }
    },

    "feature_rules": {
      "allowed_features": [
        "frog_house_cluster",
        "boardwalk_ring",
        "lily_cluster",
        "reed_patch",
        "totem_plaza",
        "small_pond"
      ],
      "feature_density": 0.5,
      "anchor_bias": 0.8
    },

    "anchors": {
      "central_plaza": {
        "feature_type": "village_center",
        "required_visual_roles": ["settlement_core"],
        "preferred_surrounding_roles": ["wood_path", "hut_base"]
      },
      "pond_cluster_east": {
        "feature_type": "decorated_pond_cluster",
        "required_region_group": "water"
      },
      "housing_cluster_west": {
        "feature_type": "hut_cluster",
        "required_visual_roles": ["hut_base", "settlement_edge"]
      }
    },

    "visual_assets": {
      "ground_stamp_set": "frog_marsh_ground_stamps",
      "shoreline_stamp_set": "frog_marsh_shoreline_stamps",
      "water_overlay_set": "frog_marsh_water_overlays",
      "settlement_prop_set": "frog_marsh_settlement_props"
    }
  }
}